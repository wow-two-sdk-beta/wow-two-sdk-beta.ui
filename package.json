{
  "name": "@wow-two-beta/ui",
  "version": "0.0.59",
  "description": "Beta-forever React UI library for the wow-two ecosystem.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wow-two-sdk-beta/wow-two-sdk-beta.ui.git"
  },
  "homepage": "https://github.com/wow-two-sdk-beta/wow-two-sdk-beta.ui#readme",
  "bugs": {
    "url": "https://github.com/wow-two-sdk-beta/wow-two-sdk-beta.ui/issues"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "wow-two",
    "beta"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js",
      "default": "./dist/icons/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js",
      "default": "./dist/primitives/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js",
      "default": "./dist/actions/index.js"
    },
    "./display": {
      "types": "./dist/display/index.d.ts",
      "import": "./dist/display/index.js",
      "default": "./dist/display/index.js"
    },
    "./feedback": {
      "types": "./dist/feedback/index.d.ts",
      "import": "./dist/feedback/index.js",
      "default": "./dist/feedback/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js",
      "default": "./dist/forms/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js",
      "default": "./dist/layout/index.js"
    },
    "./nav": {
      "types": "./dist/nav/index.d.ts",
      "import": "./dist/nav/index.js",
      "default": "./dist/nav/index.js"
    },
    "./overlays": {
      "types": "./dist/overlays/index.d.ts",
      "import": "./dist/overlays/index.js",
      "default": "./dist/overlays/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist && cp src/index.css dist/index.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "playground": "pnpm --filter playground dev",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.0",
    "@radix-ui/react-focus-scope": "^1.1.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "marked": "^18.0.3",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@storybook/addon-docs": "10.3.6",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.14.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.3.6",
    "storybook-addon-pseudo-states": "10.3.6",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vite": "^6.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
